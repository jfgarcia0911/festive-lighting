PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Persistent storage (optional) — Supabase Postgres. Without these, leads are
# stored in a local JSON file. Find both in Supabase → Project Settings → API.
# Use the SERVICE ROLE key (server-side secret), never the anon key.
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Email notifications (optional). Get a free key at https://resend.com.
# Without these, lead capture still works — it just skips the email.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# NOTIFY_EMAIL=you@example.com
# FROM_EMAIL=Festive Lighting Pros <onboarding@resend.dev>